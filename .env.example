# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend CORS (update for production)
FRONTEND_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Cloudflare R2
CLOUDFLARE_ACCESS_KEY=your-r2-access-key
CLOUDFLARE_SECRET_KEY=your-r2-secret-key
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=soundbridg
CLOUDFLARE_R2_PUBLIC_URL=https://your-r2-public-url.com

# JWT (generate a strong random string for production)
JWT_SECRET=change-me-to-a-secure-random-string-64-chars-minimum

# FFmpeg (Render provides this automatically)
FFMPEG_PATH=/usr/bin/ffmpeg
