# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend CORS (update for production)
FRONTEND_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Cloudflare R2
CLOUDFLARE_ACCESS_KEY=your-r2-access-key
CLOUDFLARE_SECRET_KEY=your-r2-secret-key
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=soundbridg
CLOUDFLARE_R2_PUBLIC_URL=https://your-r2-public-url.com

# ES256 signing — see docs/migrations/2026-04-jwt-hs256-to-es256.md
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_KID=d8c103c3-fa59-4e97-bc10-4a8a1a221f42
# Transitional — retire 24h after cutover
JWT_SECRET=...

# FFmpeg (Render provides this automatically)
FFMPEG_PATH=/usr/bin/ffmpeg
